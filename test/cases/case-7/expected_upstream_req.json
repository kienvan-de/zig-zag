{
  "config": {
    "modules": {
      "prompt_templating": {
        "prompt": {
          "template": [
            {
              "role": "system",
              "content": "You are a helpful assistant with access to tools."
            },
            {
              "role": "user",
              "content": "What's the weather in San Francisco?"
            }
          ],
          "tools": [
            {
              "type": "function",
              "function": {
                "name": "get_weather",
                "description": "Get the current weather in a given location",
                "parameters": {
                  "type": "object",
                  "properties": {
                    "location": {
                      "type": "string",
                      "description": "The city and state, e.g. San Francisco, CA"
                    }
                  },
                  "required": ["location"]
                }
              }
            }
          ],
          "model": {
            "name": "gemini-2.5-pro",
            "version": "latest"
          }
        }
      }
    },
    "stream": {
      "enabled": true
    }
  }
}